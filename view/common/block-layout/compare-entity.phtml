<?php
/**
 * Compare (any entity) page block.
 *
 * Side-by-side comparison of any two entities of the same type, with an in-page
 * type switcher (projects / people / institutions / subjects / languages /
 * genres).
 * Rendered by asset/js/dashboard-compare.js — no data-entity-type, so the
 * controller shows the switcher.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\SitePageBlockRepresentation $block
 */

// Site-page block (Module.php does not run on page controllers), so request the
// CDN + core prelude and the compare controller chain.
$this->dashboardAssets(['cdn' => true, 'controller' => 'compare']);

$siteSlug = $this->currentSite()->slug();
?>

<div class="resource-vis-block compare-block">
    <div class="compare-container"
         data-base-path="<?= $this->escapeHtmlAttr($this->basePath()) ?>"
         data-site-base="<?= $this->escapeHtmlAttr($this->basePath() . '/s/' . $siteSlug) ?>">
        <div class="rv-loading">
            <div class="rv-spinner"></div>
            <span><?= $this->translate('Loading comparison…') ?></span>
        </div>
    </div>
</div>
