<?php
/**
 * Collection Overview page block.
 *
 * Aggregate visualizations across the entire collection.
 * Loads precomputed collection-overview.json and renders charts
 * using the standard dashboard orchestrator.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\SitePageBlockRepresentation $block
 */

// Dashboard front-end assets. This is a site-page block (Module.php does not
// run on page controllers), so request the CDN + core prelude too. Single
// source of truth: ResourceVisualizations\View\Helper\DashboardAssets.
$this->dashboardAssets(['cdn' => true]);

$siteSlug = $this->currentSite()->slug();
?>

<div class="resource-vis-block dashboard-block">
    <div class="dashboard-async-container"
         data-item-id="collection-overview"
         data-base-path="<?= $this->escapeHtmlAttr($this->basePath()) ?>"
         data-site-base="<?= $this->escapeHtmlAttr($this->basePath() . '/s/' . $siteSlug) ?>">
        <div class="rv-loading">
            <div class="rv-spinner"></div>
            <span><?= $this->translate('Loading collection overview…') ?></span>
        </div>
    </div>
</div>
