<?php
/**
 * Collection Overview page block — a curated subset for the home page.
 *
 * Loads the precomputed collection-overview.json (same artifact as the full
 * "Collection Dashboard" block) but renders only the home-page-friendly charts,
 * in the amira homepage order: summary cards, AMRCs & partners map, research
 * sections, section × university, item timeline by type, resource-type ×
 * language, languages, resource types, subjects, and items by country.
 *
 * The curated selection/order lives in the `collectionOverview` layout
 * (dashboard-layouts.js); `data-layout` below tells the orchestrator to use it
 * instead of the JSON's `resourceType` (which is "section", the full layout).
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\SitePageBlockRepresentation $block
 */

// Dashboard front-end assets. This is a site-page block (Module.php does not
// run on page controllers), so request the CDN + core prelude too. Single
// source of truth: DreVisualizations\View\Helper\DashboardAssets.
$this->dashboardAssets(['cdn' => true]);

$siteSlug = $this->currentSite()->slug();
?>

<div class="resource-vis-block dashboard-block">
    <div class="dashboard-async-container"
         data-item-id="collection-overview"
         data-layout="collectionOverview"
         data-title="<?= $this->escapeHtmlAttr($this->translate('Collection overview')) ?>"
         data-base-path="<?= $this->escapeHtmlAttr($this->basePath()) ?>"
         data-site-base="<?= $this->escapeHtmlAttr($this->basePath() . '/s/' . $siteSlug) ?>">
        <div class="rv-loading">
            <div class="rv-spinner"></div>
            <span><?= $this->translate('Loading collection overview…') ?></span>
        </div>
    </div>
</div>
