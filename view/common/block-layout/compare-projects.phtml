<?php
/**
 * Compare Projects page block.
 *
 * Side-by-side comparison of two projects: select from dropdowns,
 * fetch both dashboard JSONs, and render paired charts with overlap stats.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\SitePageBlockRepresentation $block
 */

// Dashboard front-end assets with the Compare controller chain. This is a
// site-page block (Module.php does not run on page controllers), so request
// the CDN + core prelude too. Single source of truth:
// ResourceVisualizations\View\Helper\DashboardAssets.
$this->dashboardAssets(['cdn' => true, 'controller' => 'compare']);

$siteSlug = $this->currentSite()->slug();
?>

<div class="resource-vis-block compare-block">
    <div class="compare-container"
         data-base-path="<?= $this->escapeHtmlAttr($this->basePath()) ?>"
         data-site-base="<?= $this->escapeHtmlAttr($this->basePath() . '/s/' . $siteSlug) ?>">
        <div class="rv-loading">
            <div class="rv-spinner"></div>
            <span><?= $this->translate('Loading project comparison…') ?></span>
        </div>
    </div>
</div>
