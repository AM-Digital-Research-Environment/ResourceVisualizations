<?php
/**
 * Embed snippet gallery.
 *
 * A self-contained helper page that lists every embeddable DRE visualization
 * block with a live preview and a copy-paste `<iframe>` + auto-resize snippet.
 * Authors visit /s/<site>/dre-embed to grab the code for any block and drop it
 * into a third-party site.
 *
 * Dashboard blocks additionally expose their individual charts: that list is
 * built client-side from RV.LAYOUTS + RV.CHART_LABELS (the same definitions the
 * dashboards render from, so the menu can never drift), filtered to the charts
 * that actually carry data in the block's precomputed JSON.
 *
 * Runs on the bare embed layout, which loads the active theme's style.css — so
 * the page reads in the DRE theme's tokens (surfaces, inks, brand accent, fonts)
 * with the documented fallbacks as a safety net.
 *
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var array  $blocks    slug => info (label/template/kind[/itemId/layout])
 * @var string $siteSlug  current site slug
 */
$escapeHtml = $this->plugin('escapeHtml');
$escapeAttr = $this->plugin('escapeHtmlAttr');

// Make RV.LAYOUTS + RV.CHART_LABELS available for the single-chart menu below.
$this->dashboardAssets(['cdn' => true]);

// Absolute origin so a generated snippet works when pasted on another domain.
$origin = rtrim($this->serverUrl(false), '/');
$embedBase = $origin . $this->url('site/dre-embed', ['site-slug' => $siteSlug]);
$basePath = $this->basePath();

// Snippets (iframe + resize listener) are built client-side via RV.embedSnippet
// — the single source shared with the on-page copy-embed buttons — so the format
// is never restated here. Each copy target carries data-embed-* attributes.
?>
